# Cache do sync da TCGdex (regenerável com node scripts/sync-tcgdex.mjs)
data/.cache/

# Artefatos gerados pelo sync (regeneráveis; o app usa data/cards.js por padrão)
data/*.generated.js
data/*.generated.json
data/lorcana/*.generated.js
data/lorcana/*.generated.json
data/onepiece/*.generated.js
data/onepiece/*.generated.json
# data/sets/ (chunks do Pokémon) é VERSIONADO de propósito: o deploy commita o
# snapshot validado de volta (carta indexada nunca some, mesmo se a TCGdex sumir).
# Chunks por set dos outros jogos (gerados por writeGameCatalog no build)
data/*/sets/

# Páginas de set pré-renderizadas p/ SEO (geradas no build por scripts/prerender-catalog.mjs)
set/
card/

# Key local da PokemonPriceTracker (só pra teste local; NUNCA versionar)
.ppt.key
# Chaves do web push (privada VAPID + chave do sender; vão pra GitHub Secrets)
.vapid.key
.push.key
# Saídas temporárias dos probes/dry-runs da PPT
ppt-*.txt

# Configuração local do Claude Code
.claude/settings.local.json

# Dependências e cache de ferramentas (nunca versionar; apareceram de npx/wrangler
# locais — o site é estático e não tem package.json na raiz)
node_modules/
.wrangler/

# Lixo de SO/editor
Thumbs.db
.DS_Store

# MCP local (config de ferramenta, nao versionar)
.mcp.json
